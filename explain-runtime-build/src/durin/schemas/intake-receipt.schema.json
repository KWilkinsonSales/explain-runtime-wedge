{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "durin/slice0/intake-receipt/0.1.0",
  "title": "IntakeReceipt",
  "description": "What entered, what was derived, what was approved, where it was routed, what remained private, and what was rejected or held. reopenDigest makes reopen deterministic.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion",
    "receiptId",
    "intakeId",
    "createdAt",
    "whatEntered",
    "whatWasDerived",
    "whatWasApproved",
    "whatWasRejectedOrHeld",
    "whatRemainedPrivate",
    "routedTo",
    "dispositionId",
    "sourceState",
    "deletionState",
    "reopenDigest"
  ],
  "properties": {
    "contractVersion": { "const": "0.1.0" },
    "receiptId": { "type": "string", "minLength": 1 },
    "intakeId": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "whatEntered": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceArtifactId", "sourceType", "contentHash"],
      "properties": {
        "sourceArtifactId": { "type": "string", "minLength": 1 },
        "sourceType": {
          "enum": ["audio_recording", "text_note_export", "pdf_scan", "family_photo", "object_photo"]
        },
        "contentHash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      }
    },
    "whatWasDerived": { "type": "array", "items": { "type": "string" } },
    "whatWasApproved": { "type": "array", "items": { "type": "string" } },
    "whatWasRejectedOrHeld": { "type": "array", "items": { "type": "string" } },
    "whatRemainedPrivate": { "type": "array", "items": { "type": "string" } },
    "routedTo": {
      "enum": [
        "adl_business",
        "private_journal",
        "family_memory",
        "faith_study",
        "object_archive",
        "unsorted_holding",
        "restricted_health_legal"
      ]
    },
    "dispositionId": { "type": "string", "minLength": 1 },
    "sourceState": {
      "enum": ["received", "preserved", "derived", "reviewed", "admitted", "routed", "archived", "held", "rejected"]
    },
    "deletionState": {
      "enum": ["not_requested", "requested", "approved", "executed", "denied"]
    },
    "reopenDigest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
