{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "durin/slice0/theme-assertion/0.1.0",
  "title": "ThemeAssertion",
  "description": "A derived annotation over a source. Append-only: corrections supersede via links, they never overwrite. Only approved, retrievable, non-restricted assertions drive ordinary retrieval.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion",
    "assertionId",
    "sourceArtifactId",
    "derivedRepresentationId",
    "themeType",
    "value",
    "confidence",
    "evidencePointer",
    "generator",
    "reviewState",
    "reviewedBy",
    "approvedForRetrieval",
    "privacyScope",
    "assertedAt",
    "supersedesAssertionId",
    "supersededByAssertionId"
  ],
  "properties": {
    "contractVersion": { "const": "0.1.0" },
    "assertionId": { "type": "string", "minLength": 1 },
    "sourceArtifactId": { "type": "string", "minLength": 1 },
    "derivedRepresentationId": { "type": ["string", "null"] },
    "themeType": {
      "enum": [
        "person",
        "relationship",
        "event_life_chapter",
        "place_time",
        "object",
        "activity",
        "emotion_atmosphere",
        "story_memory",
        "purpose_intended_use",
        "project",
        "provenance",
        "privacy"
      ]
    },
    "value": { "type": "string", "minLength": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidencePointer": { "type": "string", "minLength": 1 },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "method"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "method": { "enum": ["human_manual", "deterministic_rule", "model_proposal"] }
      }
    },
    "reviewState": {
      "enum": ["proposed", "approved", "corrected", "rejected", "uncertain", "superseded"]
    },
    "reviewedBy": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["actorId", "actorType"],
          "properties": {
            "actorId": { "type": "string", "minLength": 1 },
            "actorType": { "enum": ["human", "system"] }
          }
        }
      ]
    },
    "approvedForRetrieval": { "type": "boolean" },
    "privacyScope": {
      "enum": [
        "adl_business",
        "private_journal",
        "family_memory",
        "faith_study",
        "object_archive",
        "unsorted_holding",
        "restricted_health_legal"
      ]
    },
    "assertedAt": { "type": "string", "format": "date-time" },
    "supersedesAssertionId": { "type": ["string", "null"] },
    "supersededByAssertionId": { "type": ["string", "null"] }
  },
  "allOf": [
    {
      "if": { "properties": { "approvedForRetrieval": { "const": true } } },
      "then": { "properties": { "reviewState": { "const": "approved" } } }
    },
    {
      "if": { "properties": { "reviewState": { "const": "proposed" } } },
      "then": { "properties": { "reviewedBy": { "type": "null" } } }
    }
  ]
}
